    {
      "name": "Películas",
      "item": [
        {
          "name": "Listar todas",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/peliculas", "host": ["{{baseUrl}}"], "path": ["api", "peliculas"] } }
        },
        {
          "name": "Crear (requiere token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Duna: Parte Dos\",\n  \"genero\": \"Ciencia Ficción\",\n  \"duracion\": 166,\n  \"sinopsis\": \"Paul Atreides continúa su viaje...\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/peliculas", "host": ["{{baseUrl}}"], "path": ["api", "peliculas"] }
          }
        },
        {
          "name": "Crear - sin token (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Test\",\n  \"genero\": \"Acción\",\n  \"duracion\": 120\n}" },
            "url": { "raw": "{{baseUrl}}/api/peliculas", "host": ["{{baseUrl}}"], "path": ["api", "peliculas"] }
          }
        },
        {
          "name": "Crear - campos faltantes (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Solo título\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/peliculas", "host": ["{{baseUrl}}"], "path": ["api", "peliculas"] }
          }
        },
        {
          "name": "Crear - duración no numérica (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Test\",\n  \"genero\": \"Acción\",\n  \"duracion\": \"ciento veinte\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/peliculas", "host": ["{{baseUrl}}"], "path": ["api", "peliculas"] }
          }
        },
        {
          "name": "Actualizar (requiere token)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Duna: Parte Dos (Actualizado)\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/peliculas/1", "host": ["{{baseUrl}}"], "path": ["api", "peliculas", "1"] }
          }
        },
        {
          "name": "Eliminar (requiere token)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/peliculas/1", "host": ["{{baseUrl}}"], "path": ["api", "peliculas", "1"] }
          }
        }
      ]
    },
    {
      "name": "Funciones",
      "item": [
        {
          "name": "Listar todas",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/funciones", "host": ["{{baseUrl}}"], "path": ["api", "funciones"] } }
        },
        {
          "name": "Filtrar por película y fecha (rq-07)",
          "request": {
            "method": "GET",
            "header": [],
