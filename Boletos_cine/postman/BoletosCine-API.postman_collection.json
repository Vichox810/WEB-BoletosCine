            "body": { "mode": "raw", "raw": "{\n  \"PeliculaId\": 1,\n  \"fecha\": \"2026-06-20\",\n  \"hora\": \"20:00\",\n  \"sala\": \"Sala 1\",\n  \"precio\": 5000\n}" },
            "url": { "raw": "{{baseUrl}}/api/funciones", "host": ["{{baseUrl}}"], "path": ["api", "funciones"] }
          }
        },
